'timeout'	  'to'	    映射和键码启用超时等待
'timeoutlen'	  'tm'	    映射和键码超时时长 (毫秒)
'title'			    Vim 自动设置窗口标题
'titlelen'		    标题占用窗口 'columns' 的百分比
'titleold'		    退出时恢复的原始窗口标题
'titlestring'		    Vim 窗口标题自定义格式
'toolbar'	  'tb'	    GUI: 工具栏显示控制选项
'toolbariconsize' 'tbis'    GTK 2: 工具栏图标尺寸
'ttimeout'		    键码启用超时等待
'ttimeoutlen'	  'ttm'     键码超时时长 (毫秒)
'ttybuiltin'	  'tbi'     优先使用内置终端功能库，再加载外部终端功能库
'ttyfast'	  'tf'	    标记高速终端连接
'ttymouse'	  'ttym'    终端输出鼠标事件编码类型
'ttyscroll'	  'tsl'     终端单次最大滚动行数
'ttytype'	  'tty'     'term' 选项别名
'undodir'	  'udir'    撤销文件存放目录
'undofile'	  'udf'	    通过撤销文件，自动保存与恢复撤销信息
'undolevels'	  'ul'	    最大可撤销更改数量
'undoreload'	  'ur'	    缓冲区最大行数，超出后重载不可撤销
'updatecount'	  'uc'	    刷新交换文件所需字符数
'updatetime'	  'ut'	    刷新交换文件所需毫秒数
'varsofttabstop'  'vsts'    多档位软制表位列宽列表
'vartabstop'	  'vts'	    多档位制表位列宽列表
'verbose'	  'vbs'     输出详细运行日志信息
'verbosefile'	  'vfile'   详细运行日志存入文件名
'viewdir'	  'vdir'    |:mkview| 视图文件存放目录
'viewoptions'	  'vop'     |:mkview| 保存视图信息项
'viminfo'	  'vi'	    启动和退出时是否读写 .viminfo 文件及具体项目设置
'viminfofile'	  'vif'	    viminfo 自定义文件名
'virtualedit'	  've'	    虚拟编辑生效模式
'visualbell'	  'vb'	    使用视觉闪烁代替响铃
'warn'			    缓冲区已修改时执行外壳命令给出警告
'weirdinvert'	  'wiv'	    适配反转显示逻辑异常的老旧终端
