'wildignore'	  'wig'     文件名补全忽略模式
'wildignorecase'  'wic'     文件名补全时忽略大小写
'wildmenu'	  'wmnu'    命令行自动补全使用弹出菜单增强模式
'wildmode'	  'wim'     'wildchar' 按键补全模式
'wildoptions'	  'wop'     命令行补全控制选项
'winaltkeys'	  'wak'     窗口系统 ALT 键处理策略
'wincolor'	  'wcr'	    已废弃，窗口局部普通字符高亮
'window'	  'wi'	    CTRL-F 和 CTRL-B 单次滚动行数
'winfixbuf'	  'wfb'     窗口固定当前缓冲区
'winfixheight'	  'wfh'     其他窗口增减时保持本窗口高度不变
'winfixwidth'	  'wfw'     其他窗口增减时保持本窗口宽度不变
'winheight'	  'wh'	    当前窗口最少行数
