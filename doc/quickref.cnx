'winminheight'	  'wmh'     任意窗口最少行数
'winminwidth'	  'wmw'     任意窗口最少列数
'winptydll'		    winpty 动态库名
'winwidth'	  'wiw'     当前窗口最少列数
'wlseat'	  'wse'	    Wayland 平台所用座位 (seat)
'wlsteal'	  'wst'	    已废弃，允许 Wayland 窗口抢占焦点
'wltimeoutlen'	  'wtm'	    Wayland 事件轮询超时 (毫秒)
'wrap'			    启用长行回绕并在下一行继续
'wrapmargin'	  'wm'	    距右边界指定字符处开始自动断行
'wrapscan'	  'ws'	    搜索到达文件尾后折回文件头继续进行
'write'			    允许执行文件写入操作
'writeany'	  'wa'	    无需 "!" 强制即可写入任意文件
'writebackup'	  'wb'	    覆盖文件时创建临时备份
'writedelay'	  'wd'	    调试专用: 每个字符屏幕输出延迟 (毫秒)
'xtermcodes'		    向 xterm 终端发送终端控制序列请求终端码
------------------------------------------------------------------------------
*Q_ur*		撤销/重做命令

|u|       N  u		撤销最近 N 个更改
|CTRL-R|  N  CTRL-R	重做最近 N 个已撤销的更改
|U|          U		撤销最近发生更改的行上全部最近的更改
------------------------------------------------------------------------------
*Q_et*		外部命令

|:shell|	:sh[ell]	打开外壳程序
|:!|		:!{command}	通过外壳执行外部命令 {command}
|K|		   K		用 'keywordprg' (缺省: "man") 查阅光标处关键字 
------------------------------------------------------------------------------
*Q_qf*		快速修复命令

|:cc|		:cc [nr]	至第 [nr] 条错误条目 (缺省为当前错误条目)
|:cnext|	:cn		至下一条错误条目
|:cprevious|	:cp		至上一条错误条目
|:clist|	:cl		列出所有错误条目
|:cfile|	:cf		从文件 'errorfile' 提取错误列表
|:cgetbuffer|	:cgetb		类似 :cbuffer，但不跳转到首条错误
|:cgetfile|	:cg		类似 :cfile，但不跳转到首条错误
|:cgetexpr|	:cgete		类似 :cexpr，但不跳转到首条错误
|:caddfile|	:caddf		通过错误文件补充错误条目到当前快修列表
|:caddbuffer|	:cad		通过错误缓冲区补充错误条目到当前快修列表
|:caddexpr|	:cadde		通过表达式计算结果补充错误条目到当前快修列表
|:cbuffer|	:cb		从缓冲区文本提取错误列表
|:cexpr|	:cex		从表达式计算结果提取错误列表
|:cquit|	:cq		不保存退出，并返回退出码 (给编译器)
|:make|		:make [args]	启动 make，读取并解析错误输出，跳转到首条错误
|:grep|		:gr[ep] [args]	执行 'grepprg' 查找匹配项，并跳转到首个匹配项
------------------------------------------------------------------------------
*Q_vc*		其他命令

|CTRL-L|	   CTRL-L	清空并重绘屏幕
|CTRL-G|	   CTRL-G	显示当前文件名 (含路径) 和光标位置
|ga|		   ga		显示光标下字符的 ASCII 值 (十进、十六进和八进)
|g8|		   g8		utf-8 编码: 以十六进制显示光标下字符的字节序列
|g_CTRL-G|	   g CTRL-G	显示光标的列、行和字符位置
|CTRL-C|	   CTRL-C	搜索时: 中断搜索
|dos-CTRL-Break|   CTRL-Break	MS-Windows: 搜索时: 中断搜索
|<Del>|		   <Del>	输入计数时: 删除最后一个数位字符
|:version|	:ve[rsion]	显示版本信息
|:mode|		:mode N		设置屏幕模式为 N (已废弃)
|:normal|	:norm[al][!] {commands}
				执行普通模式命令
|Q|		   Q		切换到 "Ex" 模式

|:redir|	:redir >{file}		重定向消息到文件 {file}
|:silent|	:silent[!] {command}	静默执行 {command} 命令
|:confirm|	:confirm {command}	退出、写入等询问未保存改动或只读文件
|:browse|	:browse {command}	使用文件选择对话框打开/读入/写入文件
------------------------------------------------------------------------------
*Q_ce*		命令行编辑

|c_<Esc>|	<Esc>		   放弃命令行 ('wildchar' 为 <Esc> 则需按两次)

|c_CTRL-V|	CTRL-V {char}	   按本义插入 {char}
|c_CTRL-V|	CTRL-V {number}    通过十进制数值形式 (最多 3 位) 输入字符
|c_CTRL-K|	CTRL-K {char1} {char2}
				   键入二合字母 (参见 |Q_di|)
|c_CTRL-R|	CTRL-R {register}  插入寄存器内容

|c_<Left>|	<Left>/<Right>	   光标左/右移动
|c_<S-Left>|	<S-Left>/<S-Right> 光标左/右移动一个单词
|c_CTRL-B|	CTRL-B/CTRL-E	   至行首/行尾

|c_<BS>|	<BS>		   删除光标前的字符
|c_<Del>|	<Del>		   删除光标下的字符
|c_CTRL-W|	CTRL-W		   删除光标前的单词
|c_CTRL-U|	CTRL-U		   删除全部字符

|c_<Up>|	<Up>/<Down>	   调出以当前命令开头的较旧/较新的命令行
|c_<S-Up>|	<S-Up>/<S-Down>	   从命令行历史中调出较旧/较新的命令行
|c_CTRL-G|	CTRL-G		   'incsearch' 激活时下一匹配项
|c_CTRL-T|	CTRL-T		   'incsearch' 激活时上一匹配项
|:history|	:his[tory]	   显示命令行历史

上下文关联的命令行补全:

|c_wildchar|	'wildchar'  (缺省: <Tab>)
				补全光标前模式；有多项匹配时，响铃并显示首项；
				再次按 'wildchar' 将显示下个匹配项
|c_CTRL-D|	CTRL-D		列出所有匹配光标前模式的匹配项
|c_CTRL-A|	CTRL-A		插入所有匹配光标前模式的匹配项
|c_CTRL-L|	CTRL-L		插入所有匹配光标前模式的匹配项的最长公共前缀
|c_CTRL-N|	CTRL-N		按 'wildchar' 后存在多项匹配时: 至下个匹配项
|c_CTRL-P|	CTRL-P		按 'wildchar' 后存在多项匹配时: 至上个匹配项
------------------------------------------------------------------------------
*Q_ra*		Ex 范围

|:range|	,		分隔两个行号
|:range|	;		同上，但解析第二个行号前先移至首个行号

|:range|	{number}	绝对行号
|:range|	.		当前行
|:range|	$		文件末行
|:range|	%		等价于 1,$ (整个文件)
|:range|	*		等价于 '<,'> (可视选区)
|:range|	't		位置标记 t 的位置
|:range|	/{pattern}[/]	下一个匹配 {pattern} 的行
|:range|	?{pattern}[?]	上一个匹配 {pattern} 的行

|:range|	+[num]		在前导行号上加上 [num] (缺省: 1)
|:range|	-[num]		从前导行号里减去 [num] (缺省: 1)
------------------------------------------------------------------------------
*Q_ex*		特殊 Ex 字符

|:bar|      |		分隔两个命令 (不适用于 ":global" 及 ":!")
|:quote|    "		开始注释

|:_%|       %		当前文件名 (仅当期待文件名时)
|:_#|       #[num]	轮换文件名或第 [num] 号文件名 (仅当期待文件名时)
	注: 以下七项按本义键入；并非特殊键！
|:<abuf>|   <abuf>	缓冲区号，用于自动命令 (仅当期待文件名时)
|:<afile>|  <afile>	文件名，用于自动命令 (仅当期待文件名时)
|:<amatch>| <amatch>	与模式匹配的内容，用于自动命令 (仅当期待文件名时)
|:<cword>|  <cword>	光标所在单词 (仅当期待文件名时)
|:<cWORD>|  <cWORD>	光标所在字串 (仅当期待文件名时) (见 |WORD|)
|:<cfile>|  <cfile>	光标所在路径名 (仅当期待文件名时)
|:<sfile>|  <sfile>	当前通过 ":source" 执行的文件名 (仅当期待文件名时)

		在 "%"、"#"、"<cfile>"、"<sfile>" 或 "<afile>" 后，可附加
		|::p|	    :p		完整路径		(path)
		|::h|	    :h		头部 (去除文件名的目录)	(head)
		|::t|	    :t		尾部 (仅使用文件名)	(tail)
		|::r|	    :r		根部 (去除扩展名)	(root)
		|::e|	    :e		扩展名			(extension)
		|::s|	    :s/{pat}/{repl}/	用 {repl} 替代 {pat}
------------------------------------------------------------------------------
*Q_st*		启动 Vim

|-vim|	   vim [options]		启动 Vim 并编辑空缓冲区
|-file|	   vim [options] {file} ..	启动 Vim 并编辑一个或多个文件
|--|	   vim [options] -		从标准输入读入文件
|-tag|	   vim [options] -t {tag}	编辑与标签 {tag} 关联的文件
|-qf|	   vim [options] -q [fname]	以快速修复模式开始编辑并显示首条错误

	常用 Vim 参数 (完整列表见 |startup-options|)

|-gui|	-g		    启动 GUI (也接受其他相关选项)

|-+|	+[num]		    至第 [num] 行 (缺省: 末行)
|-+c|	+{command}	    加载文件后执行 {command} 命令
|-+/|	+/{pat} {file} ..   至 {pat} 首个匹配项
|-v|	-v		    Vi 模式，以普通模式启动 ex                    (vi)
|-e|	-e		    Ex 模式，以 Ex 模式启动 vim                   (ex)
|-R|	-R		    只读模式，隐含 -n                      (Read-only)
|-m|	-m		    禁止修改 (复位 'write' 选项)       (modifications)
|-d|	-d		    比较模式 |diff|                             (diff)
|-b|	-b		    二进制模式                                (binary)
|-l|	-l		    lisp 模式                                   (lisp)
|-A|	-A		    阿拉伯语模式 (置位 'arabic')              (Arabic)
|-F|	-F		    波斯语模式 (置位 'fkmap' 和 'rightleft')   (Farsi)
|-H|	-H		    希伯来语模式 (置位 'hkmap' 和 'rightleft')(Hebrew)
|-V|	-V		    详细模式，显示提示信息                   (Verbose)
|-C|	-C		    兼容模式，置位 'compatible' 选项      (Compatible)
|-N|	-N		    非兼容模式，复位 'compatible' 选项  (Nocompatible)
|-r|	-r		    列出交换文件
|-r|	-r {file} ..	    恢复中断的编辑会话                       (recover)
|-n|	-n		    不创建交换文件                            (noswap)
|-o|	-o [num]	    打开 [num] 个窗口 (缺省: 每个文件一个窗口)  (open)
|-f|	-f		    GUI: 前台进程，不分叉 (fork) 新进程   (foreground)
			    Amiga: 打开窗口时不重启原有 Vim 进程 (如用于 mail)
|-s|	-s {scriptin}	    首先从 {scriptin} 脚本文件读取命令        (script)
|-w|	-w {scriptout}	    将所有输入字符追加到 {scriptout} 文件      (write)
|-W|	-W {scriptout}	    将所有输入字符写入或覆盖 {scriptout} 文件  (Write)
|-T|	-T {terminal}	    设置终端名                              (Terminal)
|-d|	-d {device}	    Amiga: 打开 {device} 作为控制台使用       (device)
|-u|	-u {vimrc}	    从指定 {vimrc} 读取初始化设置，替代其他文件 (user)
|-U|	-U {gvimrc}	    同上，但用于 GUI 初始化设置                 (User)
|-i|	-i {viminfo}	    从文件 {viminfo} 读取信息文件，替代其他文件 (info)
|---|	--		    选项结束，后续参数均为文件名
|--help|    --help	    显示参数列表并退出
|--version| --version	    显示版本信息并退出
|--|	-		    从标准输入读取文件
------------------------------------------------------------------------------
*Q_ed*		文件编辑

	        无 !: 若当前缓冲区已被修改则失败
	        有 !: 丢弃当前缓冲区的所有修改
|:edit_f|  :e[dit][!] {file}	编辑 {file}
|:edit|    :e[dit][!]		重新载入当前文件
|:enew|    :ene[w][!]		编辑无名新缓冲区
|:find|    :fin[d][!] {file}	在 'path' 中查找 {file} 文件并编辑

|CTRL-^|   N   CTRL-^		编辑轮换文件或第 N 个缓冲区 (同 ":e #N")
|gf|       gf  或 ]f		编辑光标下文件名对应的文件 (goto file)
|:pwd|     :pwd			显示当前目录名
|:cd|      :cd [path]		切换当前目录为 [path]
|:cd-|     :cd -		返回之前的当前目录
|:file|    :f[ile]		显示当前文件名及光标位置
|:file|    :f[ile] {name}	将当前文件名设为 {name}
|:files|   :files		显示所有缓冲区中的文件名
------------------------------------------------------------------------------
*Q_fl*		使用参数列表				|argument-list|

|:args|	   :ar[gs]		显示参数列表，当前文件用 "[]" 标记
|:all|	   :all  或 :sall	为参数列表的每个文件打开一个窗口
|:wn|	   :wn[ext][!]		保存文件并编辑下个文件
|:wn|	   :wn[ext][!] {file}	写入 {file} 并编辑下个文件，! 强制覆盖已有文件
|:wN|	   :wN[ext][!] [file]	保存文件并编辑上个文件

	     使用当前窗口	  新建窗口~
|:argument|  :argu[ment] N	  :sar[gument] N	至第 N 个文件
|:next|      :n[ext]		  :sn[ext]		至下一个文件
|:next_f|    :n[ext] {arglist}	  :sn[ext] {arglist}	更换参数列表，至首文件
|:Next|      :N[ext]		  :sN[ext]		至上一个文件
|:first|     :fir[st]		  :sfir[st]		至第一个文件
|:last|      :la[st]		  :sla[st]		至最后一个文件
------------------------------------------------------------------------------
*Q_wq*		写入和退出

|:w|	  :[range]w[rite][!]		保存当前文件
|:w_f|	  :[range]w[rite] {file}	另存为 {file} 文件，如果已存在则失败
|:w_f|	  :[range]w[rite]! {file}	另存为 {file} 文件。强制覆盖已有文件
|:w_a|	  :[range]w[rite][!] >>		追加写入当前文件
|:w_a|	  :[range]w[rite][!] >> {file}	追加写入 {file} 文件
|:w_c|	  :[range]w[rite] !{cmd}	将 [range] 行作为标准输入执行 {cmd}
|:up|	  :[range]up[date][!]		仅当有修改时才保存当前文件
|:wall|	  :wa[ll][!]			保存所有已修改的缓冲区

|:q|	  :q[uit]		退出无修改缓冲区。无其他非帮助缓冲区时退出 Vim
|:q|	  :q[uit]!		退出缓冲区，丢弃修改。无非帮助缓冲区时退出 Vim
|:qa|	  :qa[ll]		退出 Vim，有已修改缓冲区则失败
|:qa|	  :qa[ll]!		退出 Vim，丢弃所有修改
|:cq|	  :cq			不保存退出，并返回退出码

|:wq|	  :wq[!]		保存当前文件并退出
|:wq|	  :wq[!] {file}		另存为 {file} 文件并退出
|:xit|	  :x[it][!] [file]	类似 ":wq"，但仅当有修改时才保存
|ZZ|	     ZZ			同 ":x"
|ZQ|	     ZQ			同 ":q!"
|:xall|	  :xa[ll][!]  或 :wqall[!]
				保存所有已修改的缓冲区并退出

|:stop|	  :st[op][!]		挂起 Vim 或启动新外壳。置位 'aw' 且无 ! 则保存
|CTRL-Z|     CTRL-Z		同 ":stop"
------------------------------------------------------------------------------
*Q_ac*		自动命令

|viminfo-file|	启动时读取寄存器、位置标记、历史记录，退出时保存这些信息。

|:rviminfo|	:rv[iminfo] [file]	从 [file] 文件读取 viminfo 信息
|:rviminfo|	:rv[iminfo]! [file]	同上，但覆盖已有信息
|:wviminfo|	:wv[iminfo] [file]	将 viminfo 信息添加到 [file] 文件
|:wviminfo|	:wv[iminfo]! [file]	将 viminfo 信息写入或覆盖 [file] 文件

|modeline|	文件编辑时自动设置选项

|modeline|	vim:{set-arg}: ..	出现在文件首尾若干行 (见 'ml')，会将
					{set-arg} 作为参数传递给 |:set| 命令

|autocommand|	在特定事件发生时自动执行命令。

|:autocmd|	:au			列出所有自动命令
|:autocmd|	:au {event}		列出 {event} 事件的所有自动命令
|:autocmd|	:au {event} {pat}	列出 {event} 中匹配 {pat} 的自动命令
|:autocmd|	:au {event} {pat} {cmd}	添加 {event} 中匹配 {pat} 的自动命令
|:autocmd|	:au!			清空所有自动命令
|:autocmd|	:au! {event}		删除 {event} 事件的所有自动命令
|:autocmd|	:au! * {pat}		删除匹配 {pat} 的所有自动命令
|:autocmd|	:au! {event} {pat}	删除 {event} 中匹配 {pat} 的自动命令
|:autocmd|	:au! {event} {pat} {cmd}
			删除 {event} 中匹配 {pat} 的所有自动命令，并添加新命令
------------------------------------------------------------------------------
*Q_wi*		多窗口命令

|CTRL-W_s|	CTRL-W s  或  :split	将窗口分割为两部分             (split)
|:split_f|	:split {file}		分割窗口，并在其中一个窗口编辑 {file}
|:vsplit|	:vsplit {file}		同上，但使用垂直分割
|:vertical|	:vertical {cmd}		执行后续命令 {cmd} 时会使用垂直分割
|:sfind|	:sf[ind] {file}		分割窗口并编辑 'path' 中找到的 {file}
|:terminal|	:terminal {cmd}		打开终端窗口
|CTRL-W_]|	CTRL-W ]		分割窗口并跳转到光标下的标签
|CTRL-W_f|	CTRL-W f		分割窗口并编辑光标下的文件名    (file)
|CTRL-W_^|	CTRL-W ^		分割窗口并编辑轮换文件
|CTRL-W_n|	CTRL-W n  或  :new	新建空窗口                       (new)
|CTRL-W_q|	CTRL-W q  或  :q[uit]	退出编辑并关闭窗口              (quit)
|CTRL-W_c|	CTRL-W c  或  :clo[se]	隐藏当前缓冲区并关闭窗口       (close)
|CTRL-W_o|	CTRL-W o  或  :on[ly]	仅保留当前窗口可见              (only)

|CTRL-W_j|	CTRL-W j		至下方窗口
|CTRL-W_k|	CTRL-W k		至上方窗口
|CTRL-W_CTRL-W|	CTRL-W CTRL-W		至下方窗口 (循环切换)           (Wrap)
|CTRL-W_W|	CTRL-W W		至上方窗口 (循环切换)           (wrap)
|CTRL-W_t|	CTRL-W t		至顶端窗口                       (top)
|CTRL-W_b|	CTRL-W b		至底端窗口                    (bottom)
|CTRL-W_p|	CTRL-W p		至上次访问的窗口            (previous)

|CTRL-W_r|	CTRL-W r		向下旋转窗口                  (rotate)
|CTRL-W_R|	CTRL-W R		向上旋转窗口                  (Rotate)
|CTRL-W_x|	CTRL-W x		将当前窗口与下一个窗口对调  (eXchange)

|CTRL-W_=|	CTRL-W =		使所有窗口等高等宽
|CTRL-W_-|	CTRL-W -		减少当前窗口高度
|CTRL-W_+|	CTRL-W +		增加当前窗口高度
|CTRL-W__|	CTRL-W _		设置当前窗口高度 (缺省: 尽可能高)

|CTRL-W_<|	CTRL-W <		减少当前窗口宽度
|CTRL-W_>|	CTRL-W >		增加当前窗口宽度
|CTRL-W_bar|	CTRL-W |		设置当前窗口宽度 (缺省: 尽可能宽)
------------------------------------------------------------------------------
*Q_bu*		缓冲区列表命令

|:buffers|	:buffers  或  :files	列出所有已知的缓冲区和文件名

|:ball|		:ball	  或  :sball	编辑所有的参数/缓冲区
|:unhide|	:unhide   或  :sunhide	编辑所有已加载的缓冲区

|:badd|		:badd {fname}		将文件名 {fname} 加入缓冲区列表
|:bunload|	:bunload[!] [N]		从内存卸载缓冲区 [N]
|:bdelete|	:bdelete[!] [N]		卸载缓冲区 [N] 并从缓冲区列表中删除

		使用当前窗口       新建窗口~
|:buffer|	:[N]buffer [N]     :[N]sbuffer [N]     至第 N 个参数/缓冲区
|:bnext|	:[N]bnext [N]      :[N]sbnext [N]      往下第 N 个参数/缓冲区
|:bNext|	:[N]bNext [N]      :[N]sbNext [N]      往上第 N 个参数/缓冲区
|:bprevious|	:[N]bprevious [N]  :[N]sbprevious [N]  往上第 N 个参数/缓冲区
|:bfirst|	:bfirst            :sbfirst            至第一个参数/缓冲区
|:blast|	:blast             :sblast             至最后一个参数/缓冲区
|:bmodified|	:[N]bmod [N]       :[N]sbmod [N]       至第 N 个修改过的缓冲区
------------------------------------------------------------------------------
*Q_sy*		语法高亮

|:syn-on|	:syntax on		开启语法高亮
|:syn-off|	:syntax off		关闭语法高亮

|:syn-keyword|	:syntax keyword {group-name} {keyword} ..
					添加语法关键字项目
|:syn-match|	:syntax match {group-name} {pattern} ...
					添加语法匹配项目
|:syn-region|	:syntax region {group-name} {pattern} ...
					添加语法区域项目
|:syn-sync|	:syntax sync [ccomment | lines {N} | ...]
					指定语法高亮同步方式
|:syntax|	:syntax [list]		列出当前语法项目
|:syn-clear|	:syntax clear		清除所有语法信息

|:highlight|	:highlight clear	清除所有高亮信息
|:highlight|	:highlight {group-name} {key}={arg} ..
					设置语法组 {group-name} 的高亮方式

|:filetype|	:filetype on		开启文件类型检测，不启用语法高亮
|:filetype|	:filetype plugin indent on
					开启文件类型检测、并启用自动缩进及设置
------------------------------------------------------------------------------
*Q_gu*		GUI 命令

|:gui|		:gui			UNIX: 启动 GUI
|:gui|		:gui {fname} ..		启动 GUI，然后编辑 {fname} ..

|:menu|		:menu			列出所有菜单
|:menu|		:menu {mpath}		列出 {mpath} 开头的菜单
|:menu|		:menu {mpath} {rhs}	添加菜单项 {mpath}，执行命令为 {rhs}
|:menu|		:menu {pri} {mpath} {rhs}
					同上，并指定优先级 {pri}
|:menu|		:menu ToolBar.{name} {rhs}
					添加工具栏项 {name}，执行命令为 {rhs}
|:tmenu|	:tmenu {mpath} {text}	为菜单项 {mpath} 添加工具提示
|:unmenu|	:unmenu {mpath}		删除菜单项 {mpath}

------------------------------------------------------------------------------
*Q_fo*		折叠

'foldmethod'	set foldmethod=manual	手动折叠
		set foldmethod=indent	按缩进折叠
		set foldmethod=expr	按表达式 'foldexpr' 折叠
		set foldmethod=syntax	按语法区域折叠
		set foldmethod=marker	按标志 'foldmarker' 折叠

|zf|		zf{motion}		操作符: 手动创建折叠        (fold)
|:fold|		:{range}fold		为 {range} 范围内行创建折叠
|zd|		zd			删除光标所在的单层折叠      (delete)
|zD|		zD			递归删除光标所在折叠        (Delete)

|zo|		zo			展开光标所在折叠            (open)
|zO|		zO			递归展开光标所在折叠        (Open)
|zc|		zc			关闭光标所在折叠一层        (close)
|zC|		zC			递归关闭光标所在折叠        (Close)

|zm|		zm			折起更多: 减少 'foldlevel'  (more)
|zM|		zM			关闭所有折叠: 将 'foldlevel' 设为 0
|zr|		zr			减少折叠: 增加 'foldlevel'  (reduce)
|zR|		zR			展开所有折叠: 将 'foldlevel' 设为最大

|zn|		zn			不折叠: 复位 'foldenable'   (none)
|zN|		zN			正常折叠: 置位 'foldenable' (Normal)
|zi|		zi			翻转 'foldenable'           (invert)

 vim:tw=78:ts=8:noet:ft=help:norl:
